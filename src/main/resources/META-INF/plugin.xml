<idea-plugin>
    <id>com.hlsl.plugin</id>
    <name>HLSL Language Support</name>
    <vendor>DOCC</vendor>
    <description><![CDATA[
        Syntax highlighting and DXC validation for HLSL (High Level Shading Language) files.
        Supports .hlsl, .hlsli, .fx, .fxh file extensions.
        Additional extensions (.vsh, .psh, .gsh, .csh, etc.) can be added via Settings > Editor > File Types > HLSL.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="HLSL"
                implementationClass="com.hlsl.HlslFileType"
                fieldName="INSTANCE"
                language="HLSL"
                extensions="hlsl;hlsli;fx;fxh"/>

        <lang.parserDefinition
                language="HLSL"
                implementationClass="com.hlsl.parser.HlslParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="HLSL"
                implementationClass="com.hlsl.highlighting.HlslSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.hlsl.highlighting.HlslColorSettingsPage"/>

        <lang.commenter
                language="HLSL"
                implementationClass="com.hlsl.HlslCommenter"/>

        <lang.braceMatcher
                language="HLSL"
                implementationClass="com.hlsl.HlslBraceMatcher"/>

        <annotator
                language="HLSL"
                implementationClass="com.hlsl.highlighting.HlslStructNameAnnotator"/>

        <externalAnnotator
                language="HLSL"
                implementationClass="com.hlsl.validation.HlslDxcAnnotator"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.hlsl.validation.HlslDxcConfigurable"
                id="com.hlsl.validation.HlslDxcConfigurable"
                displayName="HLSL / DXC"/>

        <applicationService
                serviceImplementation="com.hlsl.validation.HlslDxcSettings"/>
    </extensions>
</idea-plugin>
